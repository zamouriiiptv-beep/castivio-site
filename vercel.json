{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)\\.webp",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)\\.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)\\.woff2",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ],
  "redirects": [
    { "source": "/en",                    "destination": "/",                   "permanent": true },
    { "source": "/en/",                   "destination": "/",                   "permanent": true },
    { "source": "/en/usa",               "destination": "/guide/usa/",         "permanent": true },
    { "source": "/en/usa/",              "destination": "/guide/usa/",         "permanent": true },
    { "source": "/en/uk",                "destination": "/guide/uk/",          "permanent": true },
    { "source": "/en/uk/",               "destination": "/guide/uk/",          "permanent": true },
    { "source": "/en/canada",            "destination": "/guide/canada/",      "permanent": true },
    { "source": "/en/canada/",           "destination": "/guide/canada/",      "permanent": true },
    { "source": "/uk",                   "destination": "/guide/uk/",          "permanent": true },
    { "source": "/uk/",                  "destination": "/guide/uk/",          "permanent": true },
    { "source": "/usa",                  "destination": "/guide/usa/",         "permanent": true },
    { "source": "/usa/",                 "destination": "/guide/usa/",         "permanent": true },
    { "source": "/canada",               "destination": "/guide/canada/",      "permanent": true },
    { "source": "/canada/",              "destination": "/guide/canada/",      "permanent": true },
    { "source": "/en/guide",             "destination": "/guide/",             "permanent": true },
    { "source": "/en/guide/",            "destination": "/guide/",             "permanent": true },
    { "source": "/en/privacy-policy",    "destination": "/privacy-policy/",    "permanent": true },
    { "source": "/en/privacy-policy/",   "destination": "/privacy-policy/",    "permanent": true },
    { "source": "/en/terms-of-service",  "destination": "/terms-of-service/",  "permanent": true },
    { "source": "/en/terms-of-service/", "destination": "/terms-of-service/",  "permanent": true },
    { "source": "/guide/khalij",         "destination": "/ar/guide/khalij/",   "permanent": true },
    { "source": "/guide/khalij/",        "destination": "/ar/guide/khalij/",   "permanent": true },
    { "source": "/guide/maghreb",        "destination": "/ar/guide/maghreb/",  "permanent": true },
    { "source": "/guide/maghreb/",       "destination": "/ar/guide/maghreb/",  "permanent": true },
    { "source": "/guide/mashriq",        "destination": "/ar/guide/mashriq/",  "permanent": true },
    { "source": "/guide/mashriq/",       "destination": "/ar/guide/mashriq/",  "permanent": true }
  ]
}
