Options -Indexes
RewriteEngine On

# ── 301 Redirects ──────────────────────────────────────────
RewriteRule ^en/?$                      /                       [R=301,L]
RewriteRule ^en/usa/?$                  /guide/usa/             [R=301,L]
RewriteRule ^en/uk/?$                   /guide/uk/              [R=301,L]
RewriteRule ^en/canada/?$               /guide/canada/          [R=301,L]
RewriteRule ^en/guide/?$                /guide/                 [R=301,L]
RewriteRule ^en/privacy-policy/?$       /privacy-policy/        [R=301,L]
RewriteRule ^en/terms-of-service/?$     /terms-of-service/      [R=301,L]
RewriteRule ^usa/?$                     /guide/usa/             [R=301,L]
RewriteRule ^uk/?$                      /guide/uk/              [R=301,L]
RewriteRule ^canada/?$                  /guide/canada/          [R=301,L]
RewriteRule ^guide/khalij/?$            /ar/guide/khalij/       [R=301,L]
RewriteRule ^guide/maghreb/?$           /ar/guide/maghreb/      [R=301,L]
RewriteRule ^guide/mashriq/?$           /ar/guide/mashriq/      [R=301,L]

# ── 404 Page ───────────────────────────────────────────────
ErrorDocument 404 /404.html

# ── Cache-Control Headers ──────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/webp              "access plus 1 year"
    ExpiresByType image/png               "access plus 1 year"
    ExpiresByType image/jpeg              "access plus 1 year"
    ExpiresByType image/svg+xml           "access plus 1 year"
    ExpiresByType image/x-icon            "access plus 1 year"
    ExpiresByType text/css                "access plus 1 year"
    ExpiresByType application/javascript  "access plus 1 year"
    ExpiresByType font/woff2              "access plus 1 year"
    ExpiresByType font/woff               "access plus 1 year"
    ExpiresByType text/html               "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|webp|png|jpg|jpeg|svg|woff2|woff|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </FilesMatch>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Compression ────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
    AddOutputFilterByType DEFLATE image/svg+xml application/json
</IfModule>
