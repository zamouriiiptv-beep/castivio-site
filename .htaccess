Options -Indexes

# ── HTTPS ─────────────────────────────────────────────────────────────────────
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── www → non-www ─────────────────────────────────────────────────────────────
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# ── صفحات قديمة → صفحات جديدة ────────────────────────────────────────────────
Redirect 301 /best-iptv-usa-guide.html     https://primeiptvplus.com/en/usa/
Redirect 301 /iptv-guide-en.html           https://primeiptvplus.com/en/guide/
Redirect 301 /iptv-guide-ar.html           https://primeiptvplus.com/guide/
Redirect 301 /iptv-guide-fr.html           https://primeiptvplus.com/fr/guide/
Redirect 301 /en.html                      https://primeiptvplus.com/en/
Redirect 301 /es/esp/ana                   https://primeiptvplus.com/es/espana/

# ── index.html → مسار نظيف ───────────────────────────────────────────────────
Redirect 301 /index.html                   https://primeiptvplus.com/
Redirect 301 /en/index.html                https://primeiptvplus.com/en/
Redirect 301 /fr/index.html                https://primeiptvplus.com/fr/
Redirect 301 /es/index.html                https://primeiptvplus.com/es/

# ── trailing slash (روابط بدون / في النهاية) ──────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.+[^/])$ /$1/ [L,R=301]

# ── صفحة 404 مخصصة ───────────────────────────────────────────────────────────
ErrorDocument 404 /404.html
